generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Practice {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  phone               String?
  monthlyFee          Float    @default(199)
  prizeCampaignActive Boolean  @default(true)
  prizeLabel          String   @default("Free hygiene clean")
  doubleRewardActive  Boolean  @default(false)
  googleReviewUrl     String   @default("https://g.page/r/demo-review")
  createdAt           DateTime @default(now())
  members             Member[]
}

model FamilyGroup {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  members   Member[]
}

model Member {
  id              String            @id @default(cuid())
  practiceId      String
  familyGroupId   String?
  name            String
  phone           String
  phoneNormalized String?
  email           String?
  memberCode      String            @unique
  memberSince     DateTime          @default(now())
  optedIn         Boolean           @default(true)
  createdAt       DateTime          @default(now())
  practice        Practice          @relation(fields: [practiceId], references: [id])
  familyGroup     FamilyGroup?      @relation(fields: [familyGroupId], references: [id])
  referralsMade   Referral[]        @relation("Referrer")
  referredBy      Referral?         @relation("Referred")
  discountCredits DiscountCredit[]
  visits          Visit[]
  messages        WhatsAppMessage[]
  reviews         ReviewRequest[]

  @@index([practiceId])
  @@index([familyGroupId])
  @@index([phoneNormalized])
}

model Referral {
  id               String           @id @default(cuid())
  referrerId       String
  referredMemberId String           @unique
  relationship     String           @default("family")
  status           String           @default("pending")
  createdAt        DateTime         @default(now())
  completedAt      DateTime?
  referrer         Member           @relation("Referrer", fields: [referrerId], references: [id])
  referred         Member           @relation("Referred", fields: [referredMemberId], references: [id])
  discountCredits  DiscountCredit[]

  @@index([referrerId, status])
  @@index([createdAt])
}

model DiscountCredit {
  id                  String    @id @default(cuid())
  memberId            String
  referralId          String?
  /// 1 = direct referral reward, 2 = level-2 override (max depth)
  rewardLevel         Int       @default(1)
  percent             Int       @default(5)
  label               String
  /// pending (hold window) | available | redeemed | cancelled
  status              String    @default("pending")
  earnedAt            DateTime  @default(now())
  availableAt         DateTime?
  redeemedAt          DateTime?
  redeemedForMemberId String?
  visitId             String?
  sourceVisitId       String?
  member              Member    @relation(fields: [memberId], references: [id])
  referral            Referral? @relation(fields: [referralId], references: [id])
  visit               Visit?    @relation(fields: [visitId], references: [id])

  @@unique([referralId, rewardLevel])
  @@index([memberId, status])
  @@index([status, availableAt])
}

model Visit {
  id                String           @id @default(cuid())
  memberId          String
  treatmentValue    Float
  friendDiscountPct Int              @default(0)
  storedDiscountPct Int              @default(0)
  discountAmount    Float            @default(0)
  finalAmount       Float
  notes             String?
  fromReferral      Boolean          @default(false)
  paidOnline        Boolean          @default(false)
  stripeSessionId   String?          @unique
  createdAt         DateTime         @default(now())
  member            Member           @relation(fields: [memberId], references: [id])
  redeemedCredits   DiscountCredit[]
  reviewRequest     ReviewRequest?

  @@index([memberId])
}

model ReviewRequest {
  id        String   @id @default(cuid())
  memberId  String
  visitId   String   @unique
  status    String   @default("sent")
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id])
  visit     Visit    @relation(fields: [visitId], references: [id])
}

model WhatsAppMessage {
  id        String   @id @default(cuid())
  memberId  String?
  phone     String
  direction String   @default("outbound")
  body      String
  createdAt DateTime @default(now())
  member    Member?  @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([phone, createdAt])
}

/// Inbound WhatsApp onboarding conversation state
model WhatsAppSession {
  id           String   @id @default(cuid())
  phone        String   @unique
  step         String   @default("start")
  referrerCode String?
  name         String?
  email        String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  type      String
  actorId   String?
  subjectId String?
  meta      String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([subjectId])
}
